# Backend Configuration

# Auth
jwt_secret=your-super-secret-jwt-key-here
jwt_algorithm=HS256

# Database
database_url=postgresql+asyncpg://username:password@host:port/database?sslmode=require

# Redis (optional)
# redis_url=redis://localhost:6379/0

# CORS
cors_origins=*

# Development
auto_create_tables=true

# Internal API
internal_api_url=http://localhost:8000
internal_secret=change-me-in-production

# AI Service (Groq)
# Get your key from: https://groq.com
openai_api_key=your-groq-api-key-here
openai_base_url=https://api.groq.com/openai/v1
openai_chat_model=openai/gpt-oss-120b
openai_temperature=0.4

# Transcription
whisper_provider=local

# TTS
tts_provider=gtts
tts_lang=en
tts_audio_expires_seconds=3600
